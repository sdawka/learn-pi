{
  "name": "learn-pi",
  "version": "0.1.0",
  "description": "Pi-mono package: a proactive ZPD-calibrated language-learning agent with spaced recall and a belief graph.",
  "type": "module",
  "keywords": [
    "pi-package",
    "learning",
    "language",
    "spaced-repetition",
    "zpd"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
